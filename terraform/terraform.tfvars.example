# ═══════════════════════════════════════════════
# Netflix Clone — Terraform Variable Values
# ═══════════════════════════════════════════════
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform/terraform.tfvars.example terraform/terraform.tfvars
#
# Then run:
#   terraform init
#   terraform plan
#   terraform apply
# ═══════════════════════════════════════════════

# ── General ───────────────────────────────────
aws_region  = "us-east-1"
project_name = "netflixclone"
environment  = "dev"

# ── S3 Media Bucket ───────────────────────────
# Must be globally unique across all AWS accounts
media_bucket_name = "netflixclone-media-storage-bucket-simple"

# ── ECR Repositories ──────────────────────────
# Set to false if you don't want ECR repos created
create_ecr_repos = true

# ── Networking ────────────────────────────────
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]
# MongoDB Atlas Connection String
# Get this from your MongoDB Atlas dashboard (Database > Connect > Drivers)
# Replace <username>, <password>, and <cluster-url> with your actual values
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>.mongodb.net/netflixclone?retryWrites=true&w=majority

# AWS S3 Configuration (for media uploads)
# AWS credentials are read from the default credential chain:
#   - AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars
#   - ~/.aws/credentials file
#   - EC2 IAM role (when deployed on AWS)
AWS_REGION=us-east-1
AWS_S3_BUCKET=netflixclone-media-storage-bucket-simple

# Server Port (default: 5001 for local dev, 5000 when deployed on ECS)
PORT=5000

# JWT Secret Key (used to sign auth tokens)
JWT_SECRET=MY_SECRET_KEY